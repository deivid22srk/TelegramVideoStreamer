<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Container da foto do chat -->
        <FrameLayout
            android:id="@+id/framePhoto"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/ivChatPhoto"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar_circle"
                android:contentDescription="Foto do chat" />

            <TextView
                android:id="@+id/tvChatInitial"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Título do chat -->
        <TextView
            android:id="@+id/tvChatTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="@id/framePhoto"
            app:layout_constraintStart_toEndOf="@id/framePhoto"
            app:layout_constraintEnd_toStartOf="@id/tvDate" />

        <!-- Data da última mensagem -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/on_surface_secondary"
            app:layout_constraintTop_toTopOf="@id/tvChatTitle"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Última mensagem -->
        <TextView
            android:id="@+id/tvLastMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:textSize="14sp"
            android:textColor="@color/on_surface_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tvChatTitle"
            app:layout_constraintStart_toEndOf="@id/framePhoto"
            app:layout_constraintEnd_toStartOf="@id/tvUnreadCount"
            app:layout_constraintBottom_toBottomOf="@id/framePhoto" />

        <!-- Badge de mensagens não lidas -->
        <TextView
            android:id="@+id/tvUnreadCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="22dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_badge"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/tvLastMessage"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
